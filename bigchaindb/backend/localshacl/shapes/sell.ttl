@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix ex: <http://example.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Shape for Sell transactions
ex:SellShape a sh:NodeShape ;
    sh:targetClass ex:SELL ;
    
    # Reference to an ADV transaction via adv_ref
    sh:property [
        sh:path ex:adv_ref ;  
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:qualifiedValueShape [
            sh:node ex:AdvShape ;
            sh:property [
                sh:path ex:status ;
                sh:hasValue "Open" ;  
            ]
        ] ;
    ] ;
    
    # Reference to a BuyOffer transaction via buyOffer_ref
    sh:property [
       sh:path ex:buyOffer_ref ;  
       sh:nodeKind sh:IRI ;  
       sh:class ex:BUYOFFER ;
       sh:minCount 1 ;
       sh:maxCount 1 ;
    ] .
